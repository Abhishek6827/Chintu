{
  "name": "interview-copilot",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder --win",
    "electron:preview": "next build && electron . --preview"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "groq-sdk": "^1.1.2",
    "multer": "^1.4.5-lts.1",
    "next": "14.2.35",
    "openai": "^6.33.0",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.interviewcopilot.app",
    "productName": "Interview Copilot",
    "directories": {
      "output": "dist-electron"
    },
    "asar": false,
    "files": [
      "electron/**/*",
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "dir",
      "icon": "electron/icon.png",
      "signAndEditExecutable": false
    },
    "forceCodeSigning": false
  }
}
