{
  "name": "chintu",
  "version": "1.0.30",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder --win --publish never",
    "electron:release": "next build && electron-builder --win --publish always",
    "electron:preview": "next build && electron . --preview"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.6.1",
    "electron-updater": "^6.8.3",
    "express": "^4.22.1",
    "groq-sdk": "^1.1.2",
    "multer": "^1.4.5-lts.1",
    "next": "14.2.35",
    "openai": "^6.33.0",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-syntax-highlighter": "^15.5.13",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.chintu.app",
    "productName": "Chintu",
    "directories": {
      "output": "dist-electron"
    },
    "asar": true,
    "files": [
      "electron/**/*",
      "out/**/*",
      "node_modules/**/*",
      "package.json",
      ".env",
      ".env.local"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Chintu"
    },
    "publish": {
      "provider": "github",
      "owner": "Abhishek6827",
      "repo": "Chintu",
      "private": true,
      "releaseType": "release"
    },
    "forceCodeSigning": false
  }
}
